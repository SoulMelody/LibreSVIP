msgid "Auto determine by phonemizer language"
msgstr "通过音素器语言自动确定"

msgid "Monosyllabic languages: treating +, +~ and +* as slur notes"
msgstr "单音节语言：将+、+~ 和 +* 作为延音符"

msgid "Polysyllabic languages: treating + as slur notes, and treating +~ or +* as syllable placeholders"
msgstr "多音节语言：将+作为延音符处理，并将+~ 或+* 作为音节占位符"

msgid "Incompatible with ARPAsing-series Phonemizers"
msgstr "与 ARPAsing系列音素器不兼容"

msgid "Compatible with ARPAsing-series Phonemizers"
msgstr "与 ARPAsing系列音素器兼容"

msgid "Plus sign handling mode"
